# HTTP
PORT=3000

# Formatting
# Used by Intl.NumberFormat for currency display in generated PDFs.
LOCALE=en-US

# Request limits
# Express-compatible size string, for example: 500kb, 1mb, 2mb.
BODY_LIMIT=1mb

# Remote logo fetch limits
LOGO_FETCH_TIMEOUT_MS=3000
LOGO_MAX_BYTES=524288

# Browser CORS
# Leave empty to disable browser cross-origin access.
# Use a comma-separated list for multiple origins.
# Use * only when you intentionally want to allow every origin.
ALLOWED_ORIGINS=

# PDF endpoint rate limiting
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Optional PDF endpoint API key
# When set, clients must send this value in the x-api-key header.
API_KEY=
